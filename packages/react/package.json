{
  "name": "@charcoal-ui/react",
  "version": "6.0.0-rc.1",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css",
    "./dist/layered.css": "./dist/layered.css"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "run-s --print-label 'build:*'",
    "build:tsdown": "tsdown",
    "build:dts": "tsc --project tsconfig.build.json --pretty --emitDeclarationOnly",
    "typecheck": "tsc --project tsconfig.build.json --pretty --noEmit",
    "clean": "rimraf dist .tsbuildinfo",
    "test": "vitest run --passWithNoTests",
    "test:browser": "vitest run --config vitest.browser.config.ts"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/warning": "^3.0.4",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/browser": "^2.1.9",
    "autoprefixer": "^10.4.19",
    "jsdom": "^24.1.0",
    "playwright": "^1.58.2",
    "postcss-nested": "^7.0.2",
    "react": "^18.3.1",
    "react-aria": "catalog:",
    "react-dom": "^18.3.1",
    "react-stately": "catalog:"
  },
  "dependencies": {
    "@charcoal-ui/foundation": "workspace:*",
    "@charcoal-ui/icons": "workspace:*",
    "@charcoal-ui/theme": "workspace:*",
    "@charcoal-ui/utils": "workspace:*",
    "@react-spring/web": "catalog:",
    "polished": "^4.1.4",
    "react-compiler-runtime": "catalog:",
    "warning": "^4.0.3"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-aria": ">=3.48.0",
    "react-stately": ">=3.46.0"
  },
  "files": [
    "src",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pixiv/charcoal.git",
    "directory": "packages/react"
  },
  "gitHead": "e1ece2e43901ae667afdd5c178040607d939dcd5"
}
